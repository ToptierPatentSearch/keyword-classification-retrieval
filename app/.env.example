# Browser-safe Supabase configuration only. Do not add OPENAI_API_KEY here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Optional for GitHub Pages project sites, for example /keyword-classification-retrieval/
VITE_BASE_PATH=/

# Stripe Checkout Edge Function secrets (configure in Supabase, not in the browser bundle)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/
VITE_STRIPE_PRICE_TEST_USD=price_your_test_usd
VITE_STRIPE_PRICE_TEST_JPY=price_your_test_jpy
VITE_STRIPE_PRICE_TEST_EUR=price_your_test_eur
VITE_STRIPE_PRICE_BUSINESS_USD=price_your_business_usd
VITE_STRIPE_PRICE_BUSINESS_JPY=price_your_business_jpy
VITE_STRIPE_PRICE_BUSINESS_EUR=price_your_business_eur

STRIPE_PRICE_TEST_USD=price_your_test_usd
STRIPE_PRICE_TEST_JPY=price_your_test_jpy
STRIPE_PRICE_TEST_EUR=price_your_test_eur
STRIPE_PRICE_BUSINESS_USD=price_your_business_usd
STRIPE_PRICE_BUSINESS_JPY=price_your_business_jpy
STRIPE_PRICE_BUSINESS_EUR=price_your_business_eur

# Frontend display prices are centralized in src/lib/pricing.ts.
